{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "anhskohbo/no-captcha": "^3.6",
        "barryvdh/laravel-dompdf": "^3.1.2",
        "consoletvs/charts": "^6.6",
        "doctrine/dbal": "^4.0",
        "google/apiclient": "^2.15",
        "guzzlehttp/guzzle": "^7.8",
        "inspector-apm/inspector-laravel": "^4.15",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.16",
        "laravel/tinker": "^3.0",
        "laravel/ui": "^4.5",
        "maatwebsite/excel": "^3.1",
        "phpoffice/phpword": "^1.0",
        "psr/simple-cache": "^3.0",
        "pusher/pusher-php-server": "^7.2",
        "rats/zkteco": "^002.0",
        "socialiteproviders/microsoft": "^4.2",
        "spatie/laravel-activitylog": "^4.8",
        "spatie/laravel-permission": "^6.9",
        "stevebauman/location": "^7.1",
        "symfony/expression-language": "^7.0",
        "symfony/http-client": "^7.0",
        "symfony/mailgun-mailer": "^7.0",
        "symfony/postmark-mailer": "^7.0"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.0",
        "fakerphp/faker": "^1.23",
        "fruitcake/laravel-debugbar": "^4.2",
        "laravel/sail": "^1.32",
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^11.0",
        "spatie/laravel-ignition": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
        "app/helper.php"
    ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php -r \"file_exists('public/.htaccess') || copy('public/.htaccess.example', 'public/.htaccess');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('public/.htaccess') || copy('public/.htaccess.example', 'public/.htaccess');\""
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
