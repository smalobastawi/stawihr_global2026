APP_NAME="StawiHR-Demo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password
DB_COLLATION=utf8mb4_unicode_ci

CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mail_username
MAIL_PASSWORD=your_mail_password
MAIL_FROM_ADDRESS=your_email@example.com
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME='Your App Name'

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
JAVA_API_KEY=

NOCAPTCHA_SITEKEY=
NOCAPTCHA_SECRET=

# Google OAuth (Optional - register your app at Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8081/auth/google/callback

GOOGLE_SHEET_TABLE_NAME=your_database_table_name
GOOGLE_SHEET_RANGE=Sheet1!A1:Z1000

SMS_PARTNER_ID=
SMS_API_KEY=
SMS_SHORT_CODE=YOUR_SHORT_CODE

2FA_LOGIN=false
2FA_PASSWORD_CHANGE=false
PASSWORD_EXPIRY=false
PASSWORD_EXPIRY_DAYS=90

# Azure OAuth (Optional - register your app at Azure Portal)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:8081/login/azure/callback
AZURE_TENANT_ID=

# Stawi Self Portal integration
PORTAL_BASE_URL=http://localhost:8000
PORTAL_API_TOKEN=
HR_BACKEND_API_TOKEN=

# Biometric / Biotime integration (disabled by default)
BIOMETRIC_ENABLED=false
BIOTIME_API_URL=http://localhost:8003/biotime/api
BIOTIME_API_TOKEN=